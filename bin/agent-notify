#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -eq 0 ]; then
  echo "usage: ./bin/agent-notify <command>"
  echo 'example: ./bin/agent-notify "codex --help"'
  exit 1
fi

command_text="$*"
name="agent"
watch_ready="no"

case "$command_text" in
  codex|codex\ *)
    name="codex"
    watch_ready="yes"
    ;;
  claude|claude\ *)
    name="claude"
    ;;
esac

if [ "$watch_ready" = "yes" ]; then
  PYTHONPATH=src python3 -m telegram_agent_notify --watch-ready --shell --name "$name" -- "$command_text"
else
  PYTHONPATH=src python3 -m telegram_agent_notify --shell --name "$name" -- "$command_text"
fi
