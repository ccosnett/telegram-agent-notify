#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -eq 0 ]; then
  echo "usage: ./bin/agent-notify <command>"
  echo 'example: ./bin/agent-notify "codex --help"'
  exit 1
fi

command_text="$*"
name="agent"
watch_ready="no"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
project_root="$(cd "$script_dir/.." && pwd)"

case "$command_text" in
  codex|codex\ *)
    name="codex"
    watch_ready="yes"
    ;;
  claude|claude\ *)
    name="claude"
    ;;
esac

args=(--shell --name "$name" -- "$command_text")
[ "$watch_ready" = "yes" ] && args=(--watch-ready "${args[@]}")

exec env \
  PYTHONPATH="$project_root/src" \
  TELEGRAM_AGENT_NOTIFY_HOME="$project_root" \
  python3 -m telegram_agent_notify "${args[@]}"
